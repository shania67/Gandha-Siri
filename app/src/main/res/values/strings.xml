    <!-- GUIDE -->
    <string name="farmer_guide">Farmer Guide</string>
    <string name="legal_guidelines_title">Legal Guidelines for Sandalwood</string>
    <string name="legal_guidelines_content">"• Sandalwood cultivation is legal in many Indian states.\n• Farmers are allowed to grow sandalwood on private land.\n• Registration with forest department is recommended.\n• Trees must be documented before harvesting.\n• Transit permit is required."</string>
    <string name="harvesting_procedure_title">Harvesting Procedure</string>
    <string name="harvesting_procedure_content">"• Inform Forest Department before cutting.\n• Only mature trees should be harvested.\n• Official inspection may be required.\n• Obtain cutting permission.\n• Sell through authorized channels."</string>
    <string name="tree_security_title">Tree Security Tips</string>
    <string name="tree_security_content">"• Install fencing around plantation.\n• Use solar lights.\n• Avoid isolated planting zones.\n• Maintain digital records.\n• Use SOS in emergencies."</string>
    <string name="growth_maintenance_title">Growth &amp; Maintenance</string>
    <string name="growth_maintenance_content">"• Measure girth regularly.\n• Maintain spacing.\n• Ensure sunlight.\n• Use organic fertilizers.\n• Monitor health."</string>
    <string name="guide_important_note_title">Important Note</string>
    <string name="guide_important_note_content">"This app helps maintain digital records of sandalwood trees.\n\nAlways verify rules with official government sources.\n\nGandha-Siri supports safe and legal cultivation."</string>

