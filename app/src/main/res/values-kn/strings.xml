    <!-- GUIDE -->
    <string name="farmer_guide">ರೈತ ಮಾರ್ಗದರ್ಶಿ</string>
    <string name="legal_guidelines_title">ಶ್ರೀಗಂಧದ ಕಾನೂನು ಮಾರ್ಗಸೂಚಿಗಳು</string>
    <string name="legal_guidelines_content">"• ಶ್ರೀಗಂಧದ ಕೃಷಿ ಅನೇಕ ಭಾರತೀಯ ರಾಜ್ಯಗಳಲ್ಲಿ ಕಾನೂನುಬದ್ಧವಾಗಿದೆ.\n• ರೈತರು ಖಾಸಗಿ ಜಮೀನಿನಲ್ಲಿ ಶ್ರೀಗಂಧ ಬೆಳೆಯಲು ಅವಕಾಶವಿದೆ.\n• ಅರಣ್ಯ ಇಲಾಖೆಯಲ್ಲಿ ನೋಂದಣಿ ಮಾಡಿಕೊಳ್ಳಲು ಶಿಫಾರಸು ಮಾಡಲಾಗಿದೆ.\n• ಕಟಾವು ಮಾಡುವ ಮೊದಲು ಮರಗಳನ್ನು ದಾಖಲಿಸಬೇಕು.\n• ಸಾರಿಗೆ ಪರವಾನಗಿ ಅಗತ್ಯವಿದೆ."</string>
    <string name="harvesting_procedure_title">ಕಟಾವು ಪ್ರಕ್ರಿಯೆ</string>
    <string name="harvesting_procedure_content">"• ಕತ್ತರಿಸುವ ಮೊದಲು ಅರಣ್ಯ ಇಲಾಖೆಗೆ ತಿಳಿಸಿ.\n• ಪ್ರೌಢ ಮರಗಳನ್ನು ಮಾತ್ರ ಕಟಾವು ಮಾಡಬೇಕು.\n• ಅಧಿಕೃತ ತಪಾಸಣೆ ಅಗತ್ಯವಿರಬಹುದು.\n• ಕತ್ತರಿಸುವ ಅನುಮತಿ ಪಡೆಯಿರಿ.\n• ಅಧಿಕೃತ ಚಾನಲ್‌ಗಳ ಮೂಲಕ ಮಾರಾಟ ಮಾಡಿ."</string>
    <string name="tree_security_title">ಮರಗಳ ಭದ್ರತಾ ಸಲಹೆಗಳು</string>
    <string name="tree_security_content">"• ತೋಟದ ಸುತ್ತಲೂ ಬೇಲಿ ಹಾಕಿ.\n• ಸೌರ ದೀಪಗಳನ್ನು ಬಳಸಿ.\n• ಪ್ರತ್ಯೇಕವಾದ ನೆಟ್ಟ ವಲಯಗಳನ್ನು ತಪ್ಪಿಸಿ.\n• ಡಿಜಿಟಲ್ ದಾಖಲೆಗಳನ್ನು ನಿರ್ವಹಿಸಿ.\n• ತುರ್ತು ಸಂದರ್ಭಗಳಲ್ಲಿ SOS ಬಳಸಿ."</string>
    <string name="growth_maintenance_title">ಬೆಳವಣಿಗೆ ಮತ್ತು ನಿರ್ವಹಣೆ</string>
    <string name="growth_maintenance_content">"• ನಿಯಮಿತವಾಗಿ ಸುತ್ತಳತೆಯನ್ನು ಅಳೆಯಿರಿ.\n• ಅಂತರವನ್ನು ಕಾಯ್ದುಕೊಳ್ಳಿ.\n• ಸೂರ್ಯನ ಬೆಳಕನ್ನು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ.\n• ಸಾವಯವ ಗೊಬ್ಬರಗಳನ್ನು ಬಳಸಿ.\n• ಆರೋಗ್ಯವನ್ನು ಮೇಲ್ವಿಚಾರಣೆ ಮಾಡಿ."</string>
    <string name="guide_important_note_title">ಪ್ರಮುಖ ಸೂಚನೆ</string>
    <string name="guide_important_note_content">"ಈ ಅಪ್ಲಿಕೇಶನ್ ಶ್ರೀಗಂಧದ ಮರಗಳ ಡಿಜಿಟಲ್ ದಾಖಲೆಗಳನ್ನು ನಿರ್ವಹಿಸಲು ಸಹಾಯ ಮಾಡುತ್ತದೆ.\n\nಯಾವಾಗಲೂ ಅಧಿಕೃತ ಸರ್ಕಾರಿ ಮೂಲಗಳೊಂದಿಗೆ ನಿಯಮಗಳನ್ನು ಪರಿಶೀಲಿಸಿ.\n\nಗಂಧ-ಸಿರಿ ಸುರಕ್ಷಿತ ಮತ್ತು ಕಾನೂನುಬದ್ಧ ಕೃಷಿಯನ್ನು ಬೆಂಬಲಿಸುತ್ತದೆ."</string>

